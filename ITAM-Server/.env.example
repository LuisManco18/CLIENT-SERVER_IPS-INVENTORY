# --- Base de Datos PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=sql
DB_NAME=itam_db
DB_HOST=db
DB_PORT=5432

# --- Configuración de la API ---
PROJECT_NAME=ITAM Server
